{
  "id": "equifax_old_v1",
  "bureau": "Equifax",
  "format": "annualcreditreport_old",
  "components": [
    "reportConfirmationDetails",
    "personalInformation",
    "summary",
    "creditAccountsSummary",
    "otherItemsSummary",
    "accounts",
    "collections",
    "inquiries"
  ],
  "validatorMapping": {
    "reportConfirmationDetails": "validateReportConfirmationDetails",
    "personalInformation": "validatePersonalInformation",
    "summary": "validateSummary",
    "creditAccountsSummary": "validateCreditAccountsSummary",
    "otherItemsSummary": "validateOtherItemsSummary",
    "accounts": "validateAccounts",
    "collections": "validateCollections",
    "inquiries": "validateInquiries"
  },
  "retrievalHints": {
    "includeNeighbors": true,
    "maxWindowPages": 12,
    "crossPageStitching": ["accounts", "collections"]
  },
  "strict": {
    "tableConflictRule": "image_wins",
    "guessing": "forbidden",
    "countMismatchPolicy": {
      "accounts": "fail_component",
      "collections": "fail_component"
    }
  }
}
